{
  "name": "finanse-firma",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [{ "source": "/((?!api/).*)", "destination": "/index.html" }],
  "functions": {
    "api/social/plan-month.js": { "maxDuration": 60 },
    "api/categorize-ai.js": { "maxDuration": 60 }
  },
  "crons": [
    {
      "path": "/api/social/check-status",
      "schedule": "0 8 * * *"
    }
  ]
}
