# Supabase Configuration for File Watcher
# Copy this file to .env and fill in your actual values

# Your Supabase project URL
SUPABASE_URL=https://your-project-id.supabase.co

# Your Supabase SERVICE ROLE key (NOT the anon key!)
# WARNING: Keep this secret! It has admin privileges
SUPABASE_SERVICE_KEY=your-service-role-key-here

# Folder to watch for CSV files (absolute path)
# Example: /Users/yourname/Downloads/CSV
# Example: /Users/yourname/Dropbox/Finanse/CSV
WATCH_FOLDER=/path/to/csv/folder

# Optional: Folder to move processed files to (leave empty to keep in place)
# PROCESSED_FOLDER=/path/to/processed/folder
